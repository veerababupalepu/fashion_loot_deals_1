# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/pindealshub?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="PinDealsHub"

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GSC_VERIFICATION="your-google-search-console-verification"

# Pinterest
NEXT_PUBLIC_PINTEREST_ID="your-pinterest-id"

# Amazon Affiliate
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG="your-tag-20"

# AI SEO (optional - uses template-based generation if not set)
OPENAI_API_KEY=""
